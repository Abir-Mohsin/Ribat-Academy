rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'abirmohsin02@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.name is string &&
             data.email is string && data.email == request.auth.token.email &&
             data.role in ['student', 'admin'] &&
             data.createdAt == request.time;
    }

    function isValidProgress(data) {
      return data.userId == request.auth.uid &&
             data.courseId is string &&
             data.updatedAt == request.time &&
             (!('completedLessons' in data) || data.completedLessons is list) &&
             (!('completedQuizzes' in data) || data.completedQuizzes is list);
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if isSignedIn() && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'profileImage'])) ||
        isAdmin()
      );
    }

    match /courses/{courseId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /books/{bookId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /progress/{progressId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isSignedIn() && (resource == null || isOwner(resource.data.userId)) && isValidProgress(incoming());
    }

    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /certificates/{certId} {
      allow read: if true;
      allow create: if isSignedIn(); 
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow write: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /videoReviews/{reviewId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /instructors/{instructorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /live_classes/{classId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /stats/{docId} {
      allow read, write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /home_features/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /quiz_submissions/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }
  }
}
